{
  "name": "shoulders-mcp-server",
  "version": "0.2.0",
  "description": "MCP server for the Shoulders internal developer platform.",
  "main": "dist/server.js",
  "bin": {
    "shoulders-mcp-server": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "tsx --test tests/*.test.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "shoulders",
    "kubernetes",
    "developer-platform"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
